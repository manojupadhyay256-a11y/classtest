# Prisma / Database
# Use the connection strings from your Neon dashboard
DATABASE_URL="postgres://user:pass@host/neondb?sslmode=require"
DIRECT_URL="postgres://user:pass@host/neondb?sslmode=require"

# NextAuth
# Generate a secret using: openssl rand -base64 32
NEXTAUTH_SECRET="your-32-character-secret-here"

# The public URL of your Vercel project
NEXTAUTH_URL="https://your-app.vercel.app"
